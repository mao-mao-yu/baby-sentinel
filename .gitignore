# ── 隐私 / 设备配置 ──────────────────────────────────────────────────
# RTSP 密码、Discord token、BLE 地址
config.json
# Sense-U 配对密钥
baby_code.json
# 由 config.json 自动生成，含 RTSP 密码
go2rtc.yaml

# ── 数据 / 录像 ───────────────────────────────────────────────────────
# 视频分段和传感器时序（体积大，隐私）
recordings/
# 育儿日志和 BLE 协议日志（隐私）
logs/
docs/

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
*.egg-info/
dist/
build/

# ── 工具 / 二进制 ─────────────────────────────────────────────────────
# go2rtc.exe 等本地二进制，平台相关
bin/
# 逆向 APK 源码，体积大且版权敏感
sense-u-apk/

# ── IDE / 系统 ────────────────────────────────────────────────────────
.vscode/
.idea/
# Claude Code 本地设置
.claude/
*.swp
